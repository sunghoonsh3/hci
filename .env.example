# Neon PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Get yours at https://console.neon.tech/
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Anthropic API key. Used by /api/parse-audit to extract structured data from
# pasted Degree Works audits via Claude.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
